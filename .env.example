APP_ENV=dev
HOST=127.0.0.1
PORT=8000
ENABLE_AUTH=false
AUTH_API_KEYS=
AUTH_MODE=none
AUTH_API_KEY_HASHES=
AUTH_API_KEY_PEPPER=
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_AUDIENCE=
JWT_ISSUER=
LOG_LEVEL=INFO
LOG_JSON=true
LOG_FILE=

DATABASE_URL=postgresql+psycopg://brainstorm:brainstorm@postgres:5432/brainstorm  # pragma: allowlist secret
AUTO_CREATE_SCHEMA=true
RUN_DB_MIGRATIONS_ON_STARTUP=false
REDIS_URL=redis://redis:6379/0
REDIS_LOCK_TIMEOUT_SECONDS=30
REDIS_LOCK_BLOCKING_TIMEOUT_SECONDS=5
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_NAMESPACE=brainstorm-agent

LLM_MODE=heuristic
OPENAI_BASE_URL=http://litellm:4000/v1
OPENAI_API_KEY=change-me  # pragma: allowlist secret
MODEL_NAME=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=30
OPENAI_FACADE_MODEL_NAME=brainstorm-agent
REQUIRE_HUMAN_VALIDATION_FOR_TRANSITIONS=false
PROMPT_VERSION=v1
PROMPT_BASE_PATH=
